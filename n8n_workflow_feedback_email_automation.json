        "jsCode": "// תגובת SetFeedbackStatusBatch:\n//   []                             → הכל עבר בהצלחה\n//   [{success:false, message, ...}] → יש כשלונות (רק הכושלים)\nconst item = $input.first();\nconst response = item.json;\nconst chunkIndex = item.json.chunk_index || '?';\n\n// [] = הצלחה מלאה (n8n ממיר ריק ל-object ריק, או מערך ריק)\nconst isArray = Array.isArray(response);\nconst failures = isArray ? response.filter(r => r.success === false) : [];\n\nif (!isArray || failures.length === 0) {\n  console.log(`✅ [Chunk ${chunkIndex}] SetFeedbackStatusBatch: כל הרשומות נקלטו בהצלחה`);\n} else {\n  // לא עוצרים — רושמים ל-log ומשיכים\n  console.error(\n    `⚠️ [Chunk ${chunkIndex}] SetFeedbackStatusBatch: ${failures.length} כשלונות`,\n    JSON.stringify(failures)\n  );\n}\n\nreturn $input.all();"
      },
