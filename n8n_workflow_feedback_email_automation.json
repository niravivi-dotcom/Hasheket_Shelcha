      "parameters": {
        "jsCode": "// קורא ישירות מ-Runner — לא תלוי בחיבור הפיזי של ה-node\nconst result = $('HTTP: Runner /from-api1').first().json;\nif (!result.ok) {\n  throw new Error('Runner החזיר שגיאה: ' + (result.message || JSON.stringify(result)));\n}\n// update_chunks: מערך של batches מוכנים (עד 1000 רשומות כל אחד)\n// כל פריט יישלח ב-POST אחד ל-SetFeedbackStatusBatch\nconst chunks = result.update_chunks || [];\nif (chunks.length === 0) {\n  return [{ json: { chunk: [], chunk_index: 1, total_chunks: 0 } }];\n}\nreturn chunks.map((chunk, i) => ({\n  json: { chunk, chunk_index: i + 1, total_chunks: chunks.length }\n}));"
